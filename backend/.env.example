# ── Copy this file to .env and fill in values ─────────────────────────────────
# Never commit .env to git — it's in .gitignore

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
SECRET_KEY=replace-with-openssl-rand-hex-32-output

# ── Optional (sensible defaults shown) ───────────────────────────────────────
ENVIRONMENT=development
PORT=8000

# CORS — comma-separated list of allowed origins
# In production: set to your actual frontend domain
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:5500

# File uploads
MAX_UPLOAD_MB=25
UPLOAD_DIR=uploads

# Session TTL in hours
SESSION_TTL_HOURS=72

# Claude model (change to claude-opus-4-6 for harder tasks)
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# Email (optional — needed for real magic-link emails)
# Supports: resend, sendgrid, smtp
EMAIL_PROVIDER=none
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=hello@yourdomain.com

# App branding
APP_NAME=DataBro
APP_URL=http://localhost:8000

# Feature flags
DEMO_MODE=true          # Show demo login button
REQUIRE_EMAIL_VERIFY=false
